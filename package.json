{
  "name": "gait",
  "version": "2.0.0",
  "description": "GAIT — edge-native proof-of-humanity layer. Behavioral bot detection for forms, APIs, and any web action without CAPTCHA.",
  "main": "dist/gait-v2.umd.js",
  "module": "dist/gait-v2.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "build:worker": "tsc -p tsconfig.worker.json",
    "build:all": "npm run build && npm run build:worker",
    "dev": "vite",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "secret:put": "wrangler secret put GAIT_SECRET",
    "test": "vitest run",
    "lint": "eslint src worker --ext .ts",
    "lint:fix": "eslint src worker --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts' 'worker/**/*.ts' 'examples/**/*.html'",
    "prepublishOnly": "npm run build:all && npm test"
  },
  "keywords": [
    "gait",
    "bot-detection",
    "anti-bot",
    "captcha-alternative",
    "behavioral-biometrics",
    "cloudflare-workers",
    "privacy-first",
    "proof-of-humanity"
  ],
  "author": "Amit Sharma (Amit-0905)",
  "license": "Non-Commercial",
  "repository": {
    "type": "git",
    "url": "https://github.com/Amit-0905/GAIT"
  },
  "bugs": {
    "url": "https://github.com/Amit-0905/GAIT/issues"
  },
  "homepage": "https://github.com/Amit-0905/GAIT#readme",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240529.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "terser": "^5.31.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0",
    "wrangler": "^3.60.0"
  },
  "sideEffects": false
}
